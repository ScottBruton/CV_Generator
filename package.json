{
  "name": "cv-generator",
  "version": "2.0.0",
  "private": true,
  "description": "Variant-centric React CV Generator with local JSON content and PDF export",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,magenta \"vite\" \"npm run export-server\"",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "export-pdf": "node scripts/export-pdf.js",
    "export-server": "node scripts/export-server.js",
    "generate-markers": "node scripts/generate-company-markers.js",
    "start": "npm run dev",
    "run": "npm run start"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.2",
    "vite": "^7.1.0"
  }
}
