{
  "name": "cv-generator",
  "version": "1.0.0",
  "private": true,
  "description": "JSON-driven build for the engineering CV template",
  "scripts": {
    "build": "node scripts/build.js",
    "watch": "node scripts/watch.js",
    "dev": "concurrently -n watch,serve -c blue,green \"npm run watch\" \"live-server --port=3000 --watch=content,components,templates,index.html,style.css,profile.css,stat-card.css,timeline.css,impact.css,assets --wait=500\"",
    "start": "npm run build && npm run dev",
    "run": "npm run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "live-server": "^1.2.2"
  }
}
