{
  "name": "cv-generator",
  "version": "2.0.0",
  "private": true,
  "description": "Variant-centric React CV Generator with local JSON content and PDF export",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,magenta \"vite\" \"npm run export-server\"",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "export-pdf": "node scripts/export-pdf.js",
    "export-server": "node scripts/export-server.js",
    "generate-markers": "node scripts/generate-company-markers.js",
    "start": "npm run dev",
    "run": "npm run start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mozilla/readability": "^0.6.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "openai": "^6.48.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.2",
    "vite": "^7.1.0",
    "vitest": "^4.1.10"
  }
}
